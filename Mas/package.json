{
  "name": "mas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "proto": "cd src & cd domain & npx protoc --ts_opt  use_proto_field_name --ts_opt add_pb_suffix --ts_opt force_optimize_code_size --ts_opt ts_nocheck --ts_opt long_type_string --ts_out ./entities/_gen --proto_path protos protos/*.proto",
    "proto:auth": "protoc -I=protos --js_out=import_style=commonjs,binary:./src/generated --grpc-web_out=import_style=typescript,mode=grpcwebtext:./src/generated protos/*.proto",
    "dev-test": "cross-env PAGE_TO_DISPLAY=gov vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
