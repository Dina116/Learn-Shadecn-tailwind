    "devextreme-react": "^23.1.5",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "google-protobuf": "^3.21.4",
    "grpc-web-client-gen": "file:src/grpc-web-client-gen",
    "handlebars": "^4.7.8",
    "jspdf": "^4.2.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.563.0",
    "new-mas-client": "file:",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
